# Kubi v1 - Environment Configuration
# Copy to .env and configure for your deployment

# =============================================================================
# Kubi API (Bun + Hono)
# =============================================================================
KUBI_API_PORT=3000
KUBI_API_HOST=0.0.0.0
KUBI_API_KEY=sk-kubi-change-me-in-production
KUBI_API_CORS_ORIGINS=*

# =============================================================================
# Kubi Core (Rust Axum Orchestrator)
# =============================================================================
KUBI_CORE_PORT=8080
KUBI_CORE_HOST=0.0.0.0
KUBI_AI_URL=http://kubi-ai:8000
QDRANT_URL=http://qdrant:6333
REDIS_URL=redis://redis:6379
CACHE_TTL_SECONDS=300

# =============================================================================
# Kubi AI (Python FastAPI)
# =============================================================================
KUBI_AI_PORT=8000
KUBI_AI_HOST=0.0.0.0

# Embedding model (Sentence Transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Cross-encoder for reranking
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# =============================================================================
# LLM Configuration (April 2026 Latest Models)
# =============================================================================
# Provider: ollama | openai | deepseek | claude | kimi | mimo | groq | together | openrouter | mistral | perplexity | cohere | fireworks | local | custom
LLM_PROVIDER=ollama

# Override base URL (leave empty to use provider default)
LLM_BASE_URL=

# Override models (leave empty to use provider defaults)
# Latest models per provider (April 2026):
#   openai:      gpt-5, gpt-5-mini, gpt-5-nano, o3-mini, o3-pro, o4-mini
#   deepseek:    deepseek-v4-flash, deepseek-v4-pro (1M context)
#   claude:      claude-4-opus, claude-4-sonnet, claude-4-haiku, claude-3.7-sonnet
#   kimi:        kimi-k2, kimi-k2-thinking, kimi-k2.5, kimi-k2.6
#   mimo:        mimo-v2.5, mimo-v2.5-pro, mimo-v2-flash, mimo-v2-pro, mimo-v2-omni
#   groq:        llama-3.3-70b-versatile, llama-3.1-8b-instant, qwen-2.5-coder-32b, gemma-2-27b-it
#   mistral:     mistral-large-latest, mistral-small-latest, magistral-medium-latest, devstral-latest
#   perplexity:  sonar-pro, sonar, sonar-reasoning-pro, sonar-deep-research
#   cohere:      command-a, command-r-plus
#   fireworks:   accounts/fireworks/models/llama-v3p3-70b-instruct, accounts/fireworks/models/deepseek-r1
LLM_MODEL=
LLM_FAST_MODEL=
LLM_REASONING_MODEL=

# Generation params
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4096

# Override API key (leave empty to use provider env var)
LLM_API_KEY=

# --- Provider API Keys ---
# Uncomment and set the one you need

# OpenAI (gpt-5, o3-mini, o4-mini)
# OPENAI_API_KEY=sk-...

# DeepSeek (deepseek-v4-flash, deepseek-v4-pro)
# DEEPSEEK_API_KEY=sk-...

# Anthropic Claude (claude-4-opus, claude-4-sonnet, claude-4-haiku)
# ANTHROPIC_API_KEY=sk-ant-...

# Kimi / Moonshot (kimi-k2, kimi-k2-thinking, kimi-k2.5, kimi-k2.6)
# KIMI_API_KEY=sk-...

# Xiaomi MiMo (mimo-v2.5, mimo-v2.5-pro, mimo-v2-flash, mimo-v2-omni)
# MIMO_API_KEY=...

# Groq (llama-3.3-70b-versatile, qwen-2.5-coder-32b, gemma-2-27b-it)
# GROQ_API_KEY=gsk_...

# Together AI (Llama-3.3-70B, DeepSeek-R1)
# TOGETHER_API_KEY=...

# OpenRouter (any model via aggregator)
# OPENROUTER_API_KEY=sk-or-...

# Mistral (mistral-large, mistral-small, magistral-medium, devstral)
# MISTRAL_API_KEY=...

# Perplexity (sonar-pro, sonar-reasoning-pro, sonar-deep-research)
# PERPLEXITY_API_KEY=pplx-...

# Cohere (command-a, command-r-plus)
# COHERE_API_KEY=...

# Fireworks AI (llama-v3p3-70b, deepseek-r1)
# FIREWORKS_API_KEY=...

# Local OpenAI-compatible server (LM Studio, vLLM, llama.cpp server)
# LOCAL_LLM_API_KEY=

# Web Search Backends
SEARXNG_URL=http://searxng:8080
SEARXNG_ENGINES=google,bing,duckduckgo,wikipedia
DUCKDUCKGO_ENABLED=true

# Playwright (dynamic crawling)
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_TIMEOUT=15000
CRAWL_MAX_PAGES=10
CRAWL_MAX_CONCURRENT=5

# =============================================================================
# Qdrant Vector Database
# =============================================================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_WEB_PAGES=web_pages
QDRANT_COLLECTION_CACHED_RESULTS=cached_results
QDRANT_COLLECTION_DOCUMENTS=documents
QDRANT_GRPC_PORT=6334

# =============================================================================
# Redis Cache
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# =============================================================================
# SearXNG Configuration
# =============================================================================
SEARXNG_SECRET=kubi-searxng-secret-change-me

# =============================================================================
# Logging
# =============================================================================
LOG_LEVEL=info
RUST_LOG=info
PYTHON_LOG_LEVEL=INFO
